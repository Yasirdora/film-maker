# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — real secrets never get committed.
#
# Loaded automatically by the Next.js dev server (`next dev`) into
# process.env before any server code runs. Production reads come from
# `wrangler secret put <NAME>` — OpenNext's worker entrypoint copies
# them into process.env at request-init time, so the same reads work
# in both environments.

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe price ids — populated by `npm run stripe:setup`
STRIPE_PRICE_INDIE=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_STUDIO=

# Stripe topup price ids — populated by `npm run stripe:setup`
STRIPE_PRICE_TOPUP_SMALL=
STRIPE_PRICE_TOPUP_MEDIUM=
STRIPE_PRICE_TOPUP_LARGE=

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth (Better Auth provider) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Gmail (transactional sender via REST API + OAuth2 refresh token) ───────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=

# ─── Google Gemini API (image generation) ──────────────────────────────────
GOOGLE_GEMINI_API_KEY=

# ─── Cloudflare Turnstile (bot protection) ─────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Sentry (error tracking) ────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── App URLs (mirrored from wrangler.jsonc vars for local dev) ───────────
# These are also in wrangler.jsonc under `vars` for production. In dev,
# Next.js reads from this file; in prod OpenNext reads from the worker env.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STORAGE_URL=https://storage.film-maker.net
